# Shafsky FastAPI Backend Environment Placeholders
ENVIRONMENT=production
PORT=4000
DATABASE_URL=postgresql://user:password@localhost:5432/shafsky_db?sslmode=require
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your-redis-password-placeholder

JWT_SECRET=your-jwt-secret-key-placeholder
JWT_REFRESH_SECRET=your-refresh-secret-key-placeholder

# Aviation Third-Party APIs
RAPIDAPI_KEY=your-rapidapi-key-placeholder
RAPIDAPI_HOST=aerodatabox.p.rapidapi.com
AERODATABOX_BASE_URL=https://aerodatabox.p.rapidapi.com
AERODATABOX_API_KEY=your-aerodatabox-key-placeholder
AMADEUS_CLIENT_ID=
AMADEUS_CLIENT_SECRET=
AVIATIONSTACK_API_KEY=

# Email Configurations (Resend Integration)
RESEND_API_KEY=your-resend-api-key-placeholder
EMAIL_FROM=bookings@shafskyaviation.com
RESEND_FROM_EMAIL=bookings@shafskyaviation.com
EMAIL_REPLY_TO=bookings@shafskyaviation.com
COMPANY_NAME="Shafsky Aviation"

# Legacy Rollback Supabase Credentials
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=
SUPABASE_JWKS_URL=
