# ==============================================================================
# SHAFSKY AVIATION FASTAPI BACKEND - ENVIRONMENT CONFIGURATION TEMPLATE
# ==============================================================================
# Security Notice: This file (.env.example) contains ONLY placeholder values
# and safe defaults. NEVER commit real API keys, passwords, or secrets to Git.
# Copy this file to '.env' and populate real credentials for local development.
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. APPLICATION CONFIGURATION
# ------------------------------------------------------------------------------
# Environment mode (development / staging / production)
ENVIRONMENT=development
# Server HTTP port
PORT=8001
# Display project name
PROJECT_NAME="Shafsky Aviation FastAPI Backend Engine"
# Enterprise company branding name
COMPANY_NAME="Shafsky Aviation"

# ------------------------------------------------------------------------------
# 2. DATABASE & IN-MEMORY CACHE
# ------------------------------------------------------------------------------
# PostgreSQL connection string (Neon / Managed PostgreSQL)
DATABASE_URL=postgresql://your_db_user:your_db_password@your_db_host:5432/your_db_name?sslmode=require
# Redis server host
REDIS_HOST=localhost
# Redis server port
REDIS_PORT=6379
# Redis authentication password (leave empty if unauthenticated)
REDIS_PASSWORD=your_redis_password_placeholder

# ------------------------------------------------------------------------------
# 3. SECURITY & CORS
# ------------------------------------------------------------------------------
# Comma-separated allowed origin URLs for CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:5173
# Enforce strict OWASP security headers in production
SECURITY_STRICT_MODE=true

# ------------------------------------------------------------------------------
# 4. AUTHENTICATION & JWT TOKENS
# ------------------------------------------------------------------------------
# 256-bit secret key for signing short-lived Access Tokens
JWT_SECRET=your_jwt_secret_key_min_32_chars_placeholder
# 256-bit secret key for signing long-lived Refresh Tokens
JWT_REFRESH_SECRET=your_jwt_refresh_secret_key_min_32_chars_placeholder
# Access token expiration in minutes (default: 15)
ACCESS_TOKEN_EXPIRE_MINUTES=15
# Refresh token expiration in days (default: 7)
REFRESH_TOKEN_EXPIRE_DAYS=7
# Default super admin email seed
ADMIN_EMAIL=admin@shafskyaviation.com
# Default super admin password seed
ADMIN_PASSWORD=your_super_admin_password_placeholder

# ------------------------------------------------------------------------------
# 5. AERODATABOX / RAPIDAPI (FLIGHT INTELLIGENCE)
# ------------------------------------------------------------------------------
# RapidAPI key for AeroDataBox flight validation & tracking API
AERODATABOX_API_KEY=your_aerodatabox_key_placeholder
# RapidAPI master access token
RAPIDAPI_KEY=your_rapidapi_key_placeholder
# RapidAPI host header for AeroDataBox
RAPIDAPI_HOST=aerodatabox.p.rapidapi.com
# AeroDataBox REST API base URL
AERODATABOX_BASE_URL=https://aerodatabox.p.rapidapi.com

# ------------------------------------------------------------------------------
# 6. AMADEUS GDS INTEGRATION
# ------------------------------------------------------------------------------
# Amadeus API Client ID (API Key)
AMADEUS_CLIENT_ID=your_amadeus_client_id_placeholder
# Amadeus API Client Secret
AMADEUS_CLIENT_SECRET=your_amadeus_client_secret_placeholder

# ------------------------------------------------------------------------------
# 7. AVIATIONSTACK FLIGHT API
# ------------------------------------------------------------------------------
# AviationStack API key for flight status lookup
AVIATIONSTACK_API_KEY=your_aviationstack_key_placeholder

# ------------------------------------------------------------------------------
# 8. RESEND EMAIL SERVICE
# ------------------------------------------------------------------------------
# Resend API Key for transactional booking notifications
RESEND_API_KEY=re_your_resend_key_placeholder
# System sender email address
EMAIL_FROM=bookings@yourdomain.com
# Resend verified sender address
RESEND_FROM_EMAIL=bookings@yourdomain.com
# Reply-to email address for customer support
EMAIL_REPLY_TO=support@yourdomain.com

# ------------------------------------------------------------------------------
# 9. WHATSAPP & META CLOUD API (NOTIFICATIONS)
# ------------------------------------------------------------------------------
# Meta WhatsApp Business Phone Number ID
META_WA_PHONE_NUMBER_ID=your_whatsapp_phone_id_placeholder
# Meta Cloud API Permanent Access Token
META_WA_ACCESS_TOKEN=your_whatsapp_token_placeholder

# ------------------------------------------------------------------------------
# 10. PAYMENT GATEWAYS (STRIPE & RAZORPAY)
# ------------------------------------------------------------------------------
# Stripe Secret API Key
STRIPE_SECRET_KEY=sk_test_your_stripe_key_placeholder
# Stripe Webhook Endpoint Secret
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_placeholder
# Razorpay Key ID
RAZORPAY_KEY_ID=rzp_test_your_razorpay_id_placeholder
# Razorpay Key Secret
RAZORPAY_KEY_SECRET=your_razorpay_secret_placeholder

# ------------------------------------------------------------------------------
# 11. SUPABASE INTEGRATION (LEGACY / SECONDARY DATA STORE)
# ------------------------------------------------------------------------------
# Supabase project URL
SUPABASE_URL=https://your_project_ref.supabase.co
# Supabase client anonymous publishable key
SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key_placeholder
# Supabase secret key
SUPABASE_SECRET_KEY=sb_secret_your_key_placeholder
# Supabase JWKS URL for JWT validation
SUPABASE_JWKS_URL=https://your_project_ref.supabase.co/auth/v1/.well-known/jwks.json
# Supabase Anon Key
SUPABASE_ANON_KEY=your_supabase_anon_token_placeholder
# Supabase Service Role Key (Administrative Access)
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_token_placeholder